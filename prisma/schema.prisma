generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  username         String        @unique
  password         String
  fullName         String
  role             Role          @default(RESIDENT)
  email            String?
  profilePicture   String?
  created_at       DateTime      @default(now())
  activityLog      ActivityLog[]
  resident         Resident?

  @@map("users")
}

model Resident {
  id               Int               @id @default(autoincrement())
  user_id          Int?              @unique
  full_name        String
  age              Int
  gender           String
  birthday         DateTime?
  address          String
  contact          String?
  occupation       String?
  civil_status     String
  status           String            @default("Active")
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  documentRequests DocumentRequest[]
  user             User?             @relation(fields: [user_id], references: [id])

  @@map("residents")
}

model Official {
  id         Int       @id @default(autoincrement())
  name       String
  position   String
  contact    String?
  term_start DateTime  @default(now())
  term_end   DateTime?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())

  @@map("officials")
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  budget      Float?
  start_date  DateTime?
  end_date    DateTime?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  @@map("projects")
}

model Session {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  time        String
  location    String
  attendees   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("sessions")
}

model DocumentRequest {
  id             Int           @id @default(autoincrement())
  resident_id    Int
  type           String
  purpose        String
  request_date   DateTime      @default(now())
  status         RequestStatus @default(PENDING)
  processed_by   Int?
  processed_at   DateTime?
  notes          String?
  created_at     DateTime      @default(now())
  file_path      String?
  response_file  String?
  resident       Resident      @relation(fields: [resident_id], references: [id])
  attachments    DocumentRequestAttachment[]

  @@index([resident_id], map: "document_requests_resident_id_fkey")
  @@map("document_requests")
}

model DocumentRequestAttachment {
  id          Int            @id @default(autoincrement())
  request_id  Int
  file_path   String
  file_name   String
  is_admin    Boolean        @default(false)
  is_deleted  Boolean        @default(false)
  created_at  DateTime       @default(now())
  request     DocumentRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@index([request_id], map: "document_request_attachments_request_id_fkey")
  @@map("document_request_attachments")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action     String
  details    String?
  ip_address String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "activity_log_user_id_fkey")
  @@map("activity_log")
}

model Archive {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  category    String
  file_path   String
  uploaded_by Int
  created_at  DateTime @default(now())

  @@map("archives")
}

enum Role {
  ADMIN
  RESIDENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  RELEASED
  CANCELLED
}
